extends layout

block content
  // Source: https://www.geeksforgeeks.org/node-js/tags-in-pug-view-engine/
  //- Entire Menu page wrapper
  .menu_page

    //- Header with the logo & title 
    .header_container
      img.dark_logo(src="/images/Downtown_Donuts_Dark_Background.png", alt="Downtown Donuts logo")
      h1.company_title= title
    
    //- Page heading
    h2 Menu

    //- Used Copilot Assistance to create the menu off of the provided pdf
    // SIGNATURE DONUTS SECTION
    h2.menu_section SIGNATURE DONUTS
      p.section_subtitle Handcrafted fresh every morning

      //- List of signature donut items
      .menu_items
        .menu_item
          h3 Classic Glazed
          span.price $2.50
          p.description Our legendary original – light, fluffy, and perfectly glazed

        .menu_item
          h3 Maple Bacon Bar
          span.price $3.75
          p.description Rich maple glaze topped with crispy applewood bacon

        .menu_item
          h3 Boston Cream
          span.price $3.50
          p.description Bavarian cream filling, dark chocolate ganache topping

        .menu_item
          h3 Blueberry Cake
          span.price $3.25
          p.description Dense cake donut bursting with fresh blueberries

        .menu_item
          h3 Cinnamon Sugar Twist
          span.price $2.75
          p.description Hand‑twisted and tossed in cinnamon sugar

        .menu_item
          h3 Strawberry Frosted
          span.price $3.00
          p.description Vanilla donut with strawberry glaze and rainbow sprinkles

        .menu_item
          h3 Chocolate Old Fashioned
          span.price $3.25
          p.description Sour cream donut with rich chocolate glaze

        .menu_item
          h3 Lemon Poppy Seed
          span.price $3.50
          p.description Bright lemon glaze with poppy seed crunch

        .menu_item
          h3 Dulce de Leche
          span.price $3.75
          p.description Caramel cream filled, drizzled with dulce de leche

        .menu_item
          h3 PB & J
          span.price $3.75
          p.description Peanut butter glaze with raspberry jam filling

      // DONUT HOLES SECTION
      h2.menu_section DONUT HOLES
      p.section_subtitle Glazed, Chocolate, or Cinnamon Sugar
      p.section_subtitle Half Dozen $4.50 | Dozen $7.99
      p.description Mix and match flavors!

      // DRINKS SECTION
      h2.menu_section DRINKS & MORE

      //- Coffee subcategory
      h3.subheading COFFEE
      p.section_subtitle Locally roasted beans. Always fresh.

      //- Coffee menu items
      .menu_items
        .menu_item
          h3 Drip Coffee
          span.price SM $2.25 | MD $2.75 | LG $3.25
          p.description House blend or single origin

        .menu_item
          h3 Cold Brew
          span.price SM $3.50 | MD $4.00 | LG $4.50
          p.description Slow‑steeped 18 hours, smooth and bold

        .menu_item
          h3 Espresso
          span.price $3.00
          p.description Double shot pulled to order

        .menu_item
          h3 Americano
          span.price SM $3.25 | MD $3.75 | LG $4.25
          p.description Espresso and hot water, classic and clean

        .menu_item
          h3 Latte
          span.price SM $4.25 | MD $4.75 | LG $5.25
          p.description Espresso with steamed milk, choice of milk

        .menu_item
          h3 Cappuccino
          span.price SM $4.25 | MD $4.75 | LG $5.25
          p.description Equal parts espresso, steamed milk, foam

        .menu_item
          h3 Mocha
          span.price SM $4.75 | MD $5.25 | LG $5.75
          p.description Espresso, chocolate, steamed milk, whipped cream

        .menu_item
          h3 Vanilla Chai Latte
          span.price SM $4.50 | MD $5.00 | LG $5.50
          p.description Spiced chai with vanilla and steamed milk

      // ADD-ONS SECTION
      h3.subheading ADD‑ONS
      p.description Extra shot +$0.75 | Flavored syrup +$0.50 | Oat/Almond/Soy milk +$0.60
      p.description Whipped cream +$0.50 | Cold foam +$0.75

      // OTHER DRINKS SECTION
      h3.subheading OTHER DRINKS
      .menu_items
        .menu_item
          h3 Fresh Squeezed OJ
          span.price $3.50

        .menu_item
          h3 Hot Chocolate
          span.price $3.75

        .menu_item
          h3 Iced Tea (Sweet / Unsweet)
          span.price $2.50

        .menu_item
          h3 Lemonade
          span.price $2.75

        .menu_item
          h3 Milk (Whole, Chocolate, Strawberry)
          span.price $2.00

        .menu_item
          h3 Apple Cider (Seasonal)
          span.price $3.50

      // BREAKFAST BITES SECTION
      h2.menu_section BREAKFAST BITES
      .menu_items
        .menu_item
          h3 Egg & Cheese Croissant
          span.price $5.50

        .menu_item
          h3 Bacon Breakfast Sandwich
          span.price $6.25

        .menu_item
          h3 Avocado Toast
          span.price $5.75

        .menu_item
          h3 Yogurt Parfait
          span.price $4.50

      //- Footer note for catering 
      p.footer_note Catering available! Call (555) 867‑5309 or email catering@downtowndonuts.com

    //- Links to where to order (UberEats & DoorDash)
    .delivery_buttons
      a(href='https://www.ubereats.com/') Go to Uber Eats
      a(href='https://www.doordash.com/') Go to DoorDash
    
    //- Buttons to navigate to the other pages 
    footer
      a(href='/landing_page', class='nav_button') Go to the Landing Page
      a(href='/about_us', class='nav_button') Go to the About Us Page
      a(href='/customer_comments', class='nav_button') Go to the Customer Comments Page