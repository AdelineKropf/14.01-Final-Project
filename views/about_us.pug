extends layout

block content
  //- Source: https://www.geeksforgeeks.org/node-js/tags-in-pug-view-engine/
  .about_us_page
    .header_container
      img.dark_logo(src="/images/Downtown_Donuts_Dark_Background.png" alt="Logo")
      h1.company_title= title
    h2 About Us

    //- Creates the buttons to navigate to the other pages 
    footer
      button(type='button', class='goToMenu') Go to the Menu Page
      button(type='button', class='goToLandingPage') Go to the Landing Page
      button(type='button', class='goToCustomerComments') Go to the Customer Comments Page